<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Review: {{ post_title }}</title>
<style>
  :root { color-scheme: light dark; }
  * { box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
         margin: 0; padding: 1.5rem; background: #f4f5f7; color: #1c1e21; }
  @media (prefers-color-scheme: dark) { body { background: #18191a; color: #e4e6eb; } }
  h1 { font-size: 1.4rem; margin: 0 0 .25rem; }
  .meta { color: #777; margin-bottom: 1.5rem; font-size: .9rem; }
  .meta a { color: inherit; }
  .channel { margin-bottom: 2.5rem; }
  .channel > h2 { font-size: 1.1rem; text-transform: capitalize; border-bottom: 2px solid #888;
                  padding-bottom: .3rem; }
  .cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(420px, 1fr)); gap: 1rem; }
  .card { background: #fff; border-radius: 10px; padding: 1rem; box-shadow: 0 1px 3px rgba(0,0,0,.12); }
  @media (prefers-color-scheme: dark) { .card { background: #242526; } }
  .card h3 { margin: 0 0 .2rem; font-size: 1rem; }
  .when { color: #888; font-size: .85rem; margin-bottom: .6rem; }
  .media { display: flex; flex-wrap: wrap; gap: .4rem; margin-bottom: .6rem; }
  .media img, .media video { height: 130px; border-radius: 6px; object-fit: cover; }
  textarea { width: 100%; min-height: 9rem; font: inherit; font-size: .92rem; border: 1px solid #ccc;
             border-radius: 6px; padding: .5rem; resize: vertical; background: inherit; color: inherit; }
  .row { display: flex; gap: .5rem; align-items: center; margin-top: .5rem; flex-wrap: wrap; }
  button { font: inherit; padding: .35rem .9rem; border-radius: 6px; border: 1px solid #888;
           background: #e7f3ff; cursor: pointer; }
  @media (prefers-color-scheme: dark) { button { background: #3a3b3c; color: inherit; } }
  button.copied { background: #42b72a; color: white; }
  .chars { color: #888; font-size: .8rem; }
  .yt { font-size: .85rem; margin: .3rem 0; }
  code { background: rgba(128,128,128,.15); padding: .1rem .3rem; border-radius: 4px; }
  .footer { color: #888; font-size: .8rem; white-space: pre-wrap; margin-top: 2rem; }
</style>
</head>
<body>
<h1>{{ post_title }}</h1>
<div class="meta">
  {{ post_date }} · slug <code>{{ slug }}</code>
  {%- for lang, url in links.items() %} · <a href="{{ url }}" target="_blank">blog ({{ lang }})</a>{% endfor %}
  <br>After posting manually, mark it done: <code>syndicator done {{ slug }}</code>
</div>

{% for channel, packages in channels.items() %}
<section class="channel">
  <h2>{{ channel }} ({{ packages | length }} posts)</h2>
  <div class="cards">
    {% for pkg in packages %}
    <div class="card">
      <h3>#{{ pkg.index }} {{ pkg.kind }}{% if pkg.section_title %} — {{ pkg.section_title }}{% endif %}</h3>
      <div class="when">suggested: {{ pkg.suggested_date }} · {{ pkg.dir }}</div>
      <div class="media">
        {% for m in pkg.media_files %}
          {% if m.endswith('.mp4') %}
            <video src="{{ pkg.dir }}/{{ m }}" controls muted preload="metadata"></video>
          {% else %}
            <img src="{{ pkg.dir }}/{{ m }}" alt="">
          {% endif %}
        {% endfor %}
      </div>
      {% for yt in pkg.youtube_links %}<div class="yt">▶ <a href="{{ yt }}" target="_blank">{{ yt }}</a></div>{% endfor %}
      <textarea id="text-{{ channel }}-{{ pkg.index }}">{{ pkg.text }}</textarea>
      <div class="row">
        <button onclick="copyText('text-{{ channel }}-{{ pkg.index }}', this)">Copy caption</button>
        <span class="chars">{{ pkg.text | length }} chars</span>
      </div>
    </div>
    {% endfor %}
  </div>
</section>
{% endfor %}

<div class="footer">Generated {{ generated_at }} by syndicator.</div>

<script>
function copyText(id, btn) {
  const ta = document.getElementById(id);
  navigator.clipboard.writeText(ta.value).then(() => {
    btn.classList.add('copied'); btn.textContent = 'Copied!';
    setTimeout(() => { btn.classList.remove('copied'); btn.textContent = 'Copy caption'; }, 1500);
  });
}
</script>
</body>
</html>
